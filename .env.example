APP_ENV=development
APP_VERSION=0.1.0
APP_COMMIT=dev
HTTP_ADDR=:8080
PAGES_ORIGIN=https://baditaflorin.github.io
NLP_WORKER_PATH=scripts/nlp_worker.py
NLP_WORKER_TIMEOUT_SECONDS=120
LANGDETECT_JAVA_CMD=java -jar /opt/langdetect/langdetect-cli.jar
MODEL_CACHE_DIR=/models
SPACY_MODEL_POLICY=prefer_installed
STANZA_RESOURCES_DIR=/models/stanza
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
